# Copy this file to .env and replace both values before starting Compose.
JD_IMAGE_POSTGRES_PASSWORD=change-me
JD_IMAGE_MASTER_KEY=replace-with-a-base64url-key
# If the password contains @, :, /, # or other URL-reserved characters,
# set an RFC 3986 URL-encoded connection string instead:
# JD_IMAGE_DATABASE_URL=postgresql://jd_image:encoded-password@postgres:5432/jd_image
# Optional: JD_IMAGE_HTTP_PORT=8787
