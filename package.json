{
  "private": true,
  "scripts": {
    "worktree:deps": "node scripts/worktree-deps.mjs",
    "worktree:deps:status": "node scripts/worktree-deps.mjs --status",
    "build:webui:css": "node scripts/build-webui-css.mjs",
    "typecheck:webui": "tsc -p tsconfig.webui.json --noEmit",
    "build:webui": "esbuild codex_image/webui/frontend/src/main.ts --bundle --preserve-symlinks --format=iife --target=es2020 --outfile=codex_image/webui/static/app.js --sourcemap --log-level=warning && esbuild codex_image/webui/frontend/src/history.ts --bundle --preserve-symlinks --format=iife --target=es2020 --outfile=codex_image/webui/static/history.js --sourcemap --log-level=warning",
    "check:webui": "npm run build:webui:css && npm run typecheck:webui && npm run build:webui"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "konva": "^10.3.0"
  }
}
